# PocketPilot configuration defaults for local development.
# Copy to .env.local (or your Expo-compatible env source) and edit as needed.

# demo | mock | live
APP_MODE=demo

# true | false
ENABLE_DEBUG_PANEL=true

# debug | info | warn | error
LOG_LEVEL=debug

# demo | coingecko | cryptocompare
# Keep as demo in Phase 1 unless explicitly testing mocks.
QUOTE_PROVIDER=demo
