{
  "name": "pocketpilot",
  "version": "0.1.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "test": "jest --runInBand",
    "verify": "npm run lint && npm run test",
    "format": "prettier --write .",
    "secret-scan": "node scripts/secret-scan.js"
  },
  "dependencies": {
    "expo": "~54.0.0",
    "expo-asset": "~12.0.12",
    "expo-haptics": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/react": "19.1.0",
    "@types/react-dom": "19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.24.1",
    "@typescript-eslint/parser": "^8.24.1",
    "babel-preset-expo": "^55.0.10",
    "eslint": "^9.20.1",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-import": "^2.31.0",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "ts-jest": "^29.2.6",
    "typescript": "^5.9.3"
  }
}
